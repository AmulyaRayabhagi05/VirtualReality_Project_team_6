  m_Script: {fileID: 11500000, guid: bf1cef0141ffd3544b44df369bba6075, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MapManager
  dinosaurButton: {fileID: 875063933}
  planeButton: {fileID: 925892636}
  pyramidButton: {fileID: 1327460060}
  infoPanelController: {fileID: 1313141125}
  dinosaurImage: {fileID: 21300000, guid: 0c95fe3c04607dc4a8caa4f47f83faad, type: 3}
  dinosaurTitle: Dinosaur
  dinosaurText: Dinosaurs ruled the Earth for over 160 million years, evolving from
    small creatures into the diverse giants of the Triassic, Jurassic, and Cretaceous
    periods. Now you can watch the magic dinosaur bones turn into flesh within seconds
    as you step back in time to meet the giants that once ruled our planet. Feel
    free to explore the dinosaur terrain and use the fossil brush to uncover your
    hidden fossils!
  planeImage: {fileID: 21300000, guid: ea8dea8db253a76408d3c69f2bfd8d8c, type: 3}
  planeTitle: Plane
  planeText: "Designed by Lockheed to fly at twice the speed of sound, the sleek
    F-104 Starfighter set world records for speed and altitude while serving the
    U.S. and its allies\u2014feel free to try out our newly installed flight simulator
    to see these famous wings in action!"
  pyramidImage: {fileID: 21300000, guid: 6b574e998b5b3fd43a0bdadcaaf47091, type: 3}
  pyramidTitle: Pyramid
  pyramidText: Discover the wonders of the Great Pyramid, a massive stone tomb built
    by ancient builders to honor their kings and prepare them for the journey beyond.
    Explore the mysterious halls and solve the puzzles to unlock a secret path that
    leads even deeper into the heart of the pyramid.
